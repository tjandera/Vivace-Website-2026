<!-- ── Supermarket entrance intro (first visit only) ── -->
<div id="store-intro" aria-hidden="true">

  <!-- Left sliding door — shows left half of the logo -->
  <div class="si-door si-door-l">
    <div class="si-logo-half si-logo-half--l" aria-hidden="true">
      <img src="/assets/resources-design/SMU_Vivace_Logo.png" alt="">
    </div>
    <div class="si-glare"></div>
  </div>

  <!-- Right sliding door — shows right half of the logo -->
  <div class="si-door si-door-r">
    <div class="si-logo-half si-logo-half--r" aria-hidden="true">
      <img src="/assets/resources-design/SMU_Vivace_Logo.png" alt="">
    </div>
    <div class="si-glare"></div>
  </div>


</div>

<script>
(function () {
  var el = document.getElementById('store-intro');
  if (!el) return;

  // CSS already hides it for reduced-motion users, but also bail here
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    el.remove();
    return;
  }

  // Lock scroll while the intro is running
  document.body.style.overflow = 'hidden';

  // 1 — 800 ms: doors begin sliding apart
  setTimeout(function () { el.classList.add('si-opening'); }, 800);

  // 2 — 1 750 ms: overlay fades + zooms (doors fully open at ~1 680 ms)
  setTimeout(function () {
    el.classList.add('si-exit');
    document.body.style.overflow = '';
  }, 1750);

  // 3 — 2 500 ms: remove from DOM entirely
  setTimeout(function () { el.remove(); }, 2500);
}());
</script>
