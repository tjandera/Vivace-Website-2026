<!-- Events -->
<section class="events" id="events">
  <div class="container">

    <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:24px; flex-wrap:wrap; margin-bottom:36px">
      <div>
        <span class="section-eyebrow">★ Aisle 5 · Calendar</span>
        <h2 class="section-h2">On the <span class="hi">shelves</span> this month.</h2>
      </div>
      <a class="btn ghost" href="#">Full schedule →</a>
    </div>

    <div class="events-grid">
      <% events.forEach(event => { %>
        <div class="event-card">
          <div class="pic <%= event.picClass %>">
            <span class="date-pill">
              <span class="d"><%= event.day %></span>
              <span><%= event.dayLabel %></span>
            </span>
            <div style="font-family:'Bagel Fat One',sans-serif; color:#fff; font-size:42px; -webkit-text-stroke:3px var(--ink); text-stroke:3px var(--ink)">
              <%= event.wordmark %>
            </div>
          </div>
          <div class="body">
            <h3><%= event.title %></h3>
            <div class="meta">
              <span><%= event.time %></span>
              <span>·</span>
              <span><%= event.venue %></span>
            </div>
            <p><%= event.desc %></p>
          </div>
          <div class="foot">
            <span><%= event.admission %></span>
            <span class="rsvp">RSVP →</span>
          </div>
        </div>
      <% }) %>
    </div>

  </div>
</section>
