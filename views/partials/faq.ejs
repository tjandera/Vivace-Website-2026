<!-- FAQ -->
<section id="faq">
  <div class="container">
    <div class="faq-grid">

      <div class="faq-side">
        <span class="section-eyebrow">★ Aisle 4 · FAQ</span>
        <h2 class="section-h2">Questions <span class="hi">at the checkout.</span></h2>
        <p style="font-size:17px; max-width:42ch; margin-bottom:24px">Can't find your answer? Message us on our Telegram chatbot or grab the floating Chat button.</p>
        <div style="position:relative; max-width:380px">
          <img src="assets/object-receipt-detailed.svg" alt="" style="width:240px; transform:rotate(-6deg); filter:drop-shadow(8px 8px 0 var(--ink))">
          <div style="position:absolute; right:-10px; top:30px; width:120px; transform:rotate(10deg); filter:drop-shadow(4px 4px 0 var(--ink))">
            <img src="assets/sign-special-offer.svg" alt="">
          </div>
        </div>
      </div>

      <div class="faq-list">
        <% faq.forEach(item => { %>
          <details class="faq-item" <%= item.open ? 'open' : '' %>>
            <summary>
              <span class="faq-num"><%= item.num %></span>
              <%= item.question %>
              <span class="toggle">+</span>
            </summary>
            <div class="ans"><%= item.answer %></div>
          </details>
        <% }) %>
      </div>

    </div>
  </div>
</section>
