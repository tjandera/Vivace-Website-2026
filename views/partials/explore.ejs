<!-- Explore -->
<section class="explore" id="explore">
  <div class="container">

    <!-- Filter bar -->
    <div class="filter-bar">
      <div class="search-box">
        <span class="icon"></span>
        <input type="text" placeholder="Search a CCA…" id="search-input">
      </div>
      <div class="sort" id="results-count" aria-live="polite">Full shelf: loading…</div>
    </div>

    <!-- School chips -->
    <div class="chips" id="chips">
      <button class="chip active" data-cat="all" data-title="All aisles" data-count="120" data-aisle="Mart">
        <span class="dotc" style="background:var(--ink)"></span> All <span class="count">120</span>
      </button>
      <% schools.forEach(school => { %>
        <button class="chip" data-cat="<%= school.id %>" data-title="<%= school.name %>" data-count="<%= school.count %>" data-aisle="<%= school.aisle %>">
          <span class="dotc" style="background:var(<%= school.color %>)"></span>
          <%= school.name %> <span class="count"><%= school.count %></span>
        </button>
      <% }) %>
    </div>

    <!-- CCA grid — rendered from catalogue model, links to /cca/:id -->
    <div class="cca-grid" id="cca-grid" aria-live="polite">
      <% ccas.forEach(cca => { %>
        <article class="cca-card" data-cat="<%= cca.category %>">
          <div class="top <%= cca.tone %>">
            <div class="logo-circle"><%= cca.icon %></div>
            <div>
              <h3><%= cca.name %></h3>
              <div class="meta"><%= cca.categoryShort %> · <%= cca.cluster.toUpperCase() %></div>
            </div>
          </div>
          <div class="body">
            <p><%= cca.cardText %></p>
          </div>
          <div class="foot">
            <span class="badge <%= cca.badge %>"><%= cca.intake %></span>
            <a class="more" href="/cca/<%= cca.id %>">View →</a>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="more-row" id="load-more-row">
      <button class="btn load-more" id="load-more" type="button">
        <span>Load more</span><span class="arrow">→</span>
      </button>
    </div>

  </div>
</section>
