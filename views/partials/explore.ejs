<!-- Explore -->
<section class="explore" id="explore">
  <div class="container">

    <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:24px; flex-wrap:wrap; margin-bottom:18px">
      <div>
        <span class="section-eyebrow">★ Aisle 2 · Explore</span>
        <h2 class="section-h2">Aisle by <span class="hi">aisle.</span></h2>
        <p style="font-size:18px; max-width:52ch">Filter by school, search by name, fill your basket. Click a fruit above to jump-filter.</p>
      </div>
      <div class="price-rib" style="font-size:16px; padding:6px 14px;">FRESH · 120+ CCAs in stock!</div>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
      <div class="search-box">
        <span class="icon"></span>
        <input type="text" placeholder="Search a CCA…" id="search-input">
      </div>
      <div class="sort">Sort: A–Z ▾</div>
    </div>
    <div class="store-status" id="store-status" aria-live="polite">
      <div class="status-copy">Currently browsing <strong>all stocked aisles</strong>.</div>
      <div class="status-ticket">120 CCAs · receipt #VVC26</div>
    </div>

    <!-- School chips -->
    <div class="chips" id="chips">
      <button class="chip active" data-cat="all" data-title="All aisles" data-count="120" data-aisle="Mart">
        <span class="dotc" style="background:var(--ink)"></span> All <span class="count">120</span>
      </button>
      <% schools.forEach(school => { %>
        <button class="chip" data-cat="<%= school.id %>" data-title="<%= school.name %>" data-count="<%= school.count %>" data-aisle="<%= school.aisle %>">
          <span class="dotc" style="background:var(<%= school.color %>)"></span>
          <%= school.name %> <span class="count"><%= school.count %></span>
        </button>
      <% }) %>
    </div>

    <!-- CCA grid -->
    <div class="cca-grid" id="cca-grid">
      <% ccas.forEach(cca => { %>
        <article class="cca-card" data-cat="<%= cca.school %>">
          <div class="top tone-<%= cca.school %>">
            <div class="logo-circle"><%= cca.emoji %></div>
            <div>
              <h3><%= cca.name %></h3>
              <div class="meta"><%= cca.meta %></div>
            </div>
          </div>
          <div class="body">
            <p><%= cca.desc %></p>
          </div>
          <div class="foot">
            <span class="badge <%= cca.badge !== 'open' ? cca.badge : '' %>"><%= cca.badgeText %></span>
            <span class="more">View →</span>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="more-row">
      <button class="btn ghost"><span>Load 12 more</span><span>↓</span></button>
    </div>

  </div>
</section>
