<!-- Hero -->
<section class="hero basket-hero" id="home">
  <div class="hero-glow"></div>
  <div class="basket-hero-wrap">

    <div class="basket-hero-copy">
      <div class="badge-row" style="justify-content:center; margin-bottom:0">
        <span class="stamp">Annual CCA Fair</span>
        <span class="stamp pink">Pick what fills your basket</span>
      </div>
      <h1 class="hero-wordmark">VIVACE<span class="title-year">'26</span></h1>
      <div class="hero-meta">
        <span>11 - 13 August 2026</span>
        <span>SMU Concourse</span>
        <span>10:00 - 18:00</span>
      </div>
      <p class="hero-copyline">
        Choose a school umbrella from the basket, then browse the CCAs stocked under that aisle.
      </p>
    </div>

    <div class="basket-showcase" id="scene" aria-label="Top-down grocery basket with school selectors">
      <div class="market-basket" aria-hidden="true">
        <img class="basket-image" src="assets/basket2-vertical.png" alt="">
      </div>

      <!-- Decorative overlays -->
      <div class="basket-decor sun-tag is-back" aria-hidden="true">
        <img src="assets/resources-design/sun-smile.png" alt="">
      </div>
      <div class="basket-decor price-tag is-front" aria-hidden="true">
        <img src="assets/resources-design/price-burst.png" alt="">
      </div>
      <div class="basket-decor juice-tag is-back" aria-hidden="true">
        <img src="assets/resources-design/orange-juice.png" alt="">
      </div>
      <div class="basket-decor label-tag is-back" aria-hidden="true">
        <img src="assets/resources-design/produce-label.png" alt="">
      </div>
      <div class="basket-decor button-tag is-back" aria-hidden="true">
        <img src="assets/resources-design/red-button.png" alt="">
      </div>
      <div class="basket-decor clip-tag is-front" aria-hidden="true">
        <img src="assets/resources-design/cream-clip.png" alt="">
      </div>
      <div class="basket-decor croissant-tag is-back" aria-hidden="true">
        <img src="assets/resources-design/croissant.png" alt="">
      </div>
      <div class="scan-beam" aria-hidden="true"></div>

      <!-- School fruit / item buttons (driven by schools model) -->
      <% schools.forEach(school => { %>
        <button
          class="product school-fruit <%= school.basket.modifierClass %>"
          data-cat="<%= school.id %>"
          data-title="<%= school.name %>"
          data-count="<%= school.count %>"
          data-aisle="<%= school.aisle %>"
          style="<%= school.basket.style %>"
          aria-label="Filter by <%= school.name %>"
        >
          <img src="<%= school.basket.img %>" alt="">
          <span class="fruit-label"><%= school.name %></span>
          <span class="aisle-tag"><%= school.aisle %></span>
        </button>
      <% }) %>
    </div>

    <div class="basket-hero-actions">
      <a class="btn primary" href="#explore"><span>Explore schools</span><span class="arrow">-></span></a>
      <a class="btn ghost" href="#about"><span>About Vivace</span></a>
    </div>
  </div>
</section>

<aside class="basket-summary" id="basket-summary" aria-live="polite" aria-label="Selected basket item">
  <div class="summary-top">
    <div>
      <span class="summary-kicker">Basket receipt</span>
      <span class="summary-name" id="summary-name">Empty basket</span>
    </div>
    <span class="summary-count" id="summary-count">0 in view</span>
  </div>
  <p class="summary-line" id="summary-line">Pick a product to stock the Explore aisle.</p>
  <div class="summary-actions">
    <a href="#explore">View aisle</a>
    <button type="button" id="summary-clear">Clear</button>
  </div>
</aside>

<!-- Receipt marquee strip -->
<div class="receipt-strip">
  <div class="receipt-live" id="receipt-live">Receipt open · browsing all aisles</div>
  <div class="receipt-marquee" aria-hidden="true">
    <span>★ <i>Vivace</i> Mart est. 2026 ★ <em>Aisle 7</em> · ACF · <i>SICS</i> · ICON · <em>SMUX</em> · SSU · <i>GRI</i> · Academic ★ Free entry ★</span>
    <span>★ <i>Vivace</i> Mart est. 2026 ★ <em>Aisle 7</em> · ACF · <i>SICS</i> · ICON · <em>SMUX</em> · SSU · <i>GRI</i> · Academic ★ Free entry ★</span>
  </div>
</div>
