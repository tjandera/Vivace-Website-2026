<!-- Hero -->
<section class="hero basket-hero" id="home">
  <div class="hero-glow"></div>
  <div class="basket-hero-wrap">

    <!-- ── Logo + event info ── -->
    <div class="basket-hero-copy">
      <div class="badge-row" style="justify-content:center; margin-bottom:0">
        <span class="stamp">Annual CCA Fair</span>
        <span class="stamp pink">Pick what fills your basket</span>
      </div>
      <h1 class="hero-wordmark">VIVACE<span class="title-year">'26</span></h1>
      <div class="hero-meta">
        <span>13 – 14 August 2026</span>
        <span>SMU Concourse</span>
        <span>10:00 – 18:00</span>
      </div>
    </div>

    <!-- ── YouTube trailer embed ── -->
    <!-- To update: replace the `src` video ID (the part after /embed/) with the actual Vivace '26 trailer ID -->
    <div class="hero-video">
      <iframe
        src="https://www.youtube.com/embed/oTPjD5d5lbo"
        title="SMU Vivace Trailer"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>

    <!-- ── Basket zone ── -->
    <div class="basket-zone">
      <p class="basket-zone-quote" style="display:none"></p>
      <div class="find-cca-sign" aria-hidden="true">
        <img src="assets/resources-design/find_your_cca1.png" alt="">
      </div>

      <div class="find-cca-arrow" aria-hidden="true">
        <svg viewBox="0 0 56 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M28 4 L28 48" stroke="currentColor" stroke-width="7" stroke-linecap="round"/>
          <path d="M8 34 L28 56 L48 34" stroke="currentColor" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <div class="basket-showcase" id="scene" aria-label="Top-down grocery basket with school selectors">
        <div class="market-basket" aria-hidden="true">
          <img class="basket-image" src="assets/basket2-vertical.png" alt="">
        </div>

        <!-- Decorative overlays -->
        <div class="basket-decor sun-tag is-back" aria-hidden="true">
          <img src="assets/resources-design/sun-smile.png" alt="">
        </div>
        <div class="basket-decor sticker2-tag is-front" aria-hidden="true">
          <img src="assets/resources-design/sticker2.png" alt="">
        </div>
        <div class="basket-decor juice-tag is-back" aria-hidden="true">
          <img src="assets/resources-design/orange-juice.png" alt="">
        </div>
        <div class="basket-decor tomato-tag is-back" aria-hidden="true">
          <img src="assets/resources-design/tomato1.png" alt="">
        </div>
        <div class="basket-decor button-tag is-back" aria-hidden="true">
          <img src="assets/resources-design/red-button.png" alt="">
        </div>

        <div class="basket-decor croissant-tag is-back" aria-hidden="true">
          <img src="assets/resources-design/croissant.png" alt="">
        </div>
        <div class="basket-decor sticker3-tag is-front" aria-hidden="true">
          <img src="assets/resources-design/sticker3.png" alt="">
        </div>
        <div class="basket-decor sticker4-tag is-front" aria-hidden="true">
          <img src="assets/resources-design/sticker4.png" alt="">
        </div>
        <div class="basket-decor sticker1-tag is-back" aria-hidden="true">
          <img src="assets/resources-design/sticker1.png" alt="">
        </div>
        <div class="scan-beam" aria-hidden="true"></div>

        <!-- School fruit / item buttons (driven by schools model) -->
        <% schools.forEach(school => { %>
          <button
            class="product school-fruit <%= school.basket.modifierClass %>"
            data-cat="<%= school.id %>"
            data-title="<%= school.name %>"
            data-count="<%= school.count %>"
            data-aisle="<%= school.aisle %>"
            style="<%= school.basket.style %>"
            aria-label="Explore <%= school.name %>"
          >
            <img src="<%= school.basket.img %>" alt="">
            <span class="fruit-label"><%= school.fullName %></span>
            <span class="aisle-tag"><%= school.aisle %></span>
          </button>
        <% }) %>
      </div>
    </div>

    <div class="basket-hero-actions">
      <a class="btn primary" href="/explore"><span>Explore CCA</span><span class="arrow">-></span></a>
      <a class="btn ghost" href="/about"><span>About Vivace</span></a>
    </div>

  </div>
</section>

<!-- Receipt marquee strip -->
<div class="receipt-strip">
  <div class="receipt-marquee" aria-hidden="true">
    <span>★ <i>Vivace</i> Mart est. 2026 ★ &emsp;<em>Aisle 7</em>&emsp; · ACF · <i>SICS</i> · ICON · <em>SMUX</em> · SSU · <i>GRI</i> &emsp;·&emsp; <strong>Academic</strong> &emsp;★&emsp; Free entry &emsp;★</span>
    <span>★ <i>Vivace</i> Mart est. 2026 ★ &emsp;<em>Aisle 7</em>&emsp; · ACF · <i>SICS</i> · ICON · <em>SMUX</em> · SSU · <i>GRI</i> &emsp;·&emsp; <strong>Academic</strong> &emsp;★&emsp; Free entry &emsp;★</span>
  </div>
</div>
