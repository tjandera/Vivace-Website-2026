<%- include('partials/head') %>
<body>

<%- include('partials/intro') %>
<%- include('partials/nav') %>

<!-- Page header -->
<section class="page-header">
  <div class="container">
    <span class="section-eyebrow">★ Aisle 2 · Explore</span>
    <h1 class="section-h2">Aisle by <span class="hi">aisle.</span></h1>
    <p style="font-size:18px; max-width:52ch; margin:0">Filter by school, search by name, fill your basket.</p>
  </div>
</section>

<!-- CBF quick-access strip -->
<div class="cbf-strip">
  <div class="container">
    <span class="cbf-label">Jump to:</span>
    <% const cbfs = [
      { id:'acf',  name:'ACF',      color:'var(--red)'    },
      { id:'sics', name:'SICS',     color:'var(--green)'  },
      { id:'icon', name:'ICON',     color:'var(--orange)' },
      { id:'smux', name:'SMUX',     color:'var(--blue)'   },
      { id:'ssu',  name:'SSU',      color:'var(--yellow)' },
      { id:'gri',  name:'GRI',      color:'var(--pink)'   },
      { id:'acad', name:'Academic', color:'var(--ink)'    },
    ] %>
    <% cbfs.forEach(c => { %>
      <a href="/explore/<%= c.id %>" class="cbf-pill <%= activeSchool === c.id ? 'cbf-active' : '' %>" style="--cbf-color:<%= c.color %>"><%= c.name %></a>
    <% }) %>
    <% if (activeSchool) { %>
      <a href="/explore" class="cbf-pill cbf-clear">✕ Show all</a>
    <% } %>
  </div>
</div>

<!-- Main explore section (reuses the shared partial) -->
<%- include('partials/explore') %>

<%- include('partials/footer') %>

<% if (activeSchool) { %>
<script>window.VIVACE_ACTIVE_SCHOOL = '<%= activeSchool %>';</script>
<% } %>
<script src="/js/explore.js"></script>
</body>
</html>
