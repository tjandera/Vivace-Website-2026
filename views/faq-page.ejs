<%- include('partials/head') %>
<body>

<%- include('partials/intro') %>
<%- include('partials/nav') %>

<!-- Page header -->
<section class="page-header">
  <div class="container">
    <span class="section-eyebrow">★ Aisle 4 · FAQ</span>
    <h1 class="section-h2">Questions <span class="hi">at the checkout.</span></h1>
    <p style="font-size:18px; max-width:52ch; margin:0">Can't find your answer? DM us on Instagram or grab the floating Ask Us button.</p>
  </div>
</section>

<!-- FAQ -->
<section id="faq" style="padding-top:60px">
  <div class="container">
    <div class="faq-grid">

      <div class="faq-side">
        <div style="position:relative; max-width:380px">
          <img src="/assets/object-receipt-detailed.svg" alt="" style="width:240px; transform:rotate(-6deg); filter:drop-shadow(8px 8px 0 var(--ink))">
          <div style="position:absolute; right:-10px; top:30px; width:120px; transform:rotate(10deg); filter:drop-shadow(4px 4px 0 var(--ink))">
            <img src="/assets/sign-special-offer.svg" alt="">
          </div>
        </div>
      </div>

      <div class="faq-list">
        <% faq.forEach(item => { %>
          <details class="faq-item" <%= item.open ? 'open' : '' %>>
            <summary>
              <span class="faq-num"><%= item.num %></span>
              <%= item.question %>
              <span class="toggle">+</span>
            </summary>
            <div class="ans"><%= item.answer %></div>
          </details>
        <% }) %>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>

</body>
</html>
