<%- include('partials/head') %>
<body>

<%- include('partials/intro') %>
<%- include('partials/nav') %>

<!-- Page header -->
<section class="page-header">
  <div class="container">
    <span class="section-eyebrow">★ Aisle 5 · Calendar</span>
    <h1 class="section-h2">On the <span class="hi">shelves</span> this month.</h1>
    <p style="font-size:18px; max-width:52ch; margin:0">Mark your calendar — here's every Vivace event across the three days.</p>
  </div>
</section>

<!-- Events grid -->
<section class="events" id="events" id="calendar" style="padding-top:60px">
  <div class="container">

    <div class="events-grid">
      <% events.forEach(event => { %>
        <div class="event-card">
          <div class="pic <%= event.picClass %>">
            <span class="date-pill">
              <span class="d"><%= event.day %></span>
              <span><%= event.dayLabel %></span>
            </span>
            <div style="font-family:'Bagel Fat One',sans-serif; color:#fff; font-size:42px; -webkit-text-stroke:3px var(--ink); text-stroke:3px var(--ink)">
              <%= event.wordmark %>
            </div>
          </div>
          <div class="body">
            <h3><%= event.title %></h3>
            <div class="meta">
              <span><%= event.time %></span>
              <span>·</span>
              <span><%= event.venue %></span>
            </div>
            <p><%= event.desc %></p>
          </div>
          <div class="foot">
            <span><%= event.admission %></span>
            <span class="rsvp">RSVP →</span>
          </div>
        </div>
      <% }) %>
    </div>

  </div>
</section>

<%- include('partials/footer') %>

</body>
</html>
