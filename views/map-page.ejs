<%- include('partials/head') %>
<body>

<%- include('partials/intro') %>
<%- include('partials/nav') %>

<!-- Page header -->
<section class="page-header">
  <div class="container">
    <span class="section-eyebrow">★ Aisle 0 · Venue</span>
    <h1 class="section-h2">Find your <span class="hi">way around.</span></h1>
    <p style="font-size:18px; max-width:52ch; margin:0">Vivace 2026 takes place across the SMU Concourse and surrounding spaces — 13 to 14 August 2026.</p>
  </div>
</section>

<!-- Map section -->
<section style="padding:60px 22px 80px">
  <div class="container">

    <!-- Location info cards -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:18px; margin-bottom:48px">

      <div style="border:4px solid var(--ink); border-radius:18px; padding:22px; background:#fff; box-shadow:6px 6px 0 var(--ink)">
        <div style="font-family:'Fredoka',sans-serif; font-weight:700; font-size:13px; letter-spacing:.08em; text-transform:uppercase; color:var(--green); margin-bottom:8px">★ Main Stage</div>
        <div style="font-family:'Bagel Fat One',sans-serif; font-size:28px; line-height:1; margin-bottom:6px">SMU Concourse</div>
        <div style="font-family:'Fredoka',sans-serif; font-size:15px; color:#555">Level 1 · Both days<br>10:00 — 18:00</div>
      </div>

      <div style="border:4px solid var(--ink); border-radius:18px; padding:22px; background:var(--yellow); box-shadow:6px 6px 0 var(--ink)">
        <div style="font-family:'Fredoka',sans-serif; font-weight:700; font-size:13px; letter-spacing:.08em; text-transform:uppercase; color:var(--ink); margin-bottom:8px">★ Try-outs</div>
        <div style="font-family:'Bagel Fat One',sans-serif; font-size:28px; line-height:1; margin-bottom:6px">SOA Gym</div>
        <div style="font-family:'Fredoka',sans-serif; font-size:15px; color:var(--ink)">14 Aug (Fri) only<br>17:00 — 21:00</div>
      </div>

      <div style="border:4px solid var(--ink); border-radius:18px; padding:22px; background:var(--red); color:#fff; box-shadow:6px 6px 0 var(--ink)">
        <div style="font-family:'Fredoka',sans-serif; font-weight:700; font-size:13px; letter-spacing:.08em; text-transform:uppercase; opacity:.8; margin-bottom:8px">★ Closing Night</div>
        <div style="font-family:'Bagel Fat One',sans-serif; font-size:28px; line-height:1; margin-bottom:6px">Li Ka Shing Library</div>
        <div style="font-family:'Fredoka',sans-serif; font-size:15px; opacity:.85">14 Aug (Fri) only<br>18:30 — 21:00</div>
      </div>

    </div>

    <!-- Map placeholder -->
    <div style="border:4px solid var(--ink); border-radius:22px; overflow:hidden; box-shadow:8px 8px 0 var(--ink); background:var(--cream-2)">

      <!-- Map header -->
      <div style="background:var(--ink); color:#fff; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px">
        <span style="font-family:'Bagel Fat One',sans-serif; font-size:22px; letter-spacing:.02em">VIVACE MART · FLOOR PLAN</span>
        <span style="font-family:'Space Mono',monospace; font-size:12px; opacity:.7">13–14 AUG 2026 · SMU CAMPUS</span>
      </div>

      <!-- Illustrated venue grid -->
      <div style="padding:32px 24px; display:grid; grid-template-columns:1fr 1fr; gap:16px; min-height:340px">

        <div style="border:3px solid var(--ink); border-radius:14px; padding:20px; background:rgba(73,173,119,.12); display:flex; flex-direction:column; gap:8px">
          <div style="font-family:'Bagel Fat One',sans-serif; font-size:20px; color:var(--green)">Aisle 01–02</div>
          <div style="font-family:'Fredoka',sans-serif; font-weight:700; font-size:15px">ACF · SICS</div>
          <div style="font-family:'Fredoka',sans-serif; font-size:13px; color:#666">Arts & Cultural · Service & Community</div>
          <div style="margin-top:auto; font-family:'Space Mono',monospace; font-size:11px; color:var(--green)">CONCOURSE · NORTH</div>
        </div>

        <div style="border:3px solid var(--ink); border-radius:14px; padding:20px; background:rgba(241,173,43,.14); display:flex; flex-direction:column; gap:8px">
          <div style="font-family:'Bagel Fat One',sans-serif; font-size:20px; color:var(--orange)">Aisle 03–04</div>
          <div style="font-family:'Fredoka',sans-serif; font-weight:700; font-size:15px">ICON · SMUX</div>
          <div style="font-family:'Fredoka',sans-serif; font-size:13px; color:#666">International · Outdoor & Adventure</div>
          <div style="margin-top:auto; font-family:'Space Mono',monospace; font-size:11px; color:var(--orange)">CONCOURSE · EAST</div>
        </div>

        <div style="border:3px solid var(--ink); border-radius:14px; padding:20px; background:rgba(234,90,137,.12); display:flex; flex-direction:column; gap:8px">
          <div style="font-family:'Bagel Fat One',sans-serif; font-size:20px; color:var(--red)">Aisle 05–06</div>
          <div style="font-family:'Fredoka',sans-serif; font-weight:700; font-size:15px">SSU · GRI</div>
          <div style="font-family:'Fredoka',sans-serif; font-size:13px; color:#666">Sports Union · Growth & Industry</div>
          <div style="margin-top:auto; font-family:'Space Mono',monospace; font-size:11px; color:var(--red)">CONCOURSE · WEST</div>
        </div>

        <div style="border:3px solid var(--ink); border-radius:14px; padding:20px; background:rgba(76,110,245,.1); display:flex; flex-direction:column; gap:8px">
          <div style="font-family:'Bagel Fat One',sans-serif; font-size:20px; color:var(--blue)">Aisle 07</div>
          <div style="font-family:'Fredoka',sans-serif; font-weight:700; font-size:15px">Academic</div>
          <div style="font-family:'Fredoka',sans-serif; font-size:13px; color:#666">Academic Societies</div>
          <div style="margin-top:auto; font-family:'Space Mono',monospace; font-size:11px; color:var(--blue)">CONCOURSE · SOUTH</div>
        </div>

      </div>

      <!-- Map footer -->
      <div style="border-top:3px dashed rgba(26,26,26,.2); padding:16px 24px; background:rgba(255,255,255,.6); text-align:center; font-family:'Fredoka',sans-serif; font-size:14px; color:#666">
        Full venue map will be released closer to the event · Follow <strong>@smuvivace</strong> for updates
      </div>

    </div>

    <!-- Getting here -->
    <div style="margin-top:40px; border:4px solid var(--ink); border-radius:18px; padding:28px; background:#fff; box-shadow:6px 6px 0 var(--ink)">
      <h2 style="font-family:'Bagel Fat One',sans-serif; font-size:30px; margin-bottom:18px">Getting there</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:20px; font-family:'Fredoka',sans-serif">
        <div>
          <div style="font-weight:700; font-size:17px; margin-bottom:4px">🚇 MRT</div>
          <div style="color:#555">City Hall (EW13/NS25)<br>5 min walk to SMU</div>
        </div>
        <div>
          <div style="font-weight:700; font-size:17px; margin-bottom:4px">🚌 Bus</div>
          <div style="color:#555">Bras Basah Rd stops<br>70, 130, 131, 162, 167</div>
        </div>
        <div>
          <div style="font-weight:700; font-size:17px; margin-bottom:4px">🅿️ Parking</div>
          <div style="color:#555">Bras Basah Complex<br>& CHIJMES carparks</div>
        </div>
        <div>
          <div style="font-weight:700; font-size:17px; margin-bottom:4px">📍 Address</div>
          <div style="color:#555">81 Victoria St<br>Singapore 188065</div>
        </div>
      </div>
    </div>

  </div>
</section>

<%- include('partials/footer') %>

</body>
</html>
