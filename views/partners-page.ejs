<%- include('partials/head', { page: 'partners' }) %>
<body class="sponsors-page">

<%- include('partials/nav') %>

<%- include('partials/intro') %>

<main class="sponsors-main">

  <!-- ── Hero image ── -->
  <section class="sponsors-hero" aria-label="Thank you to our sponsors">
    <img class="sponsors-hero-img"
         src="/assets/resources-design/thank_you_sponsors.png"
         alt="Thank You To Our Sponsors">
  </section>

  <!-- ── Shelf grid ── -->
  <div class="sponsors-shell">
    <div class="sponsor-shelf-grid">
      <% partners.tiers.forEach((tier, index) => { %>
        <section class="sponsor-shelf <%= tier.className %>"
                 aria-labelledby="tier-<%= index %>"
                 style="--tier-color: <%= tier.color %>">

          <div class="shelf-surface">
            <div class="sponsor-logos">
              <% if (tier.sponsors.length === 0) { %>
                <div class="sponsor-tba"><span>Coming Soon</span></div>
              <% } else { %>
                <% tier.sponsors.forEach(sponsor => { %>
                  <article class="sponsor-logo-card">
                    <% if (sponsor.logo) { %>
                      <img src="<%= sponsor.logo %>" alt="<%= sponsor.name %>" loading="lazy">
                    <% } else { %>
                      <span><%= sponsor.name %></span>
                    <% } %>
                  </article>
                <% }) %>
              <% } %>
            </div>
          </div>

          <!-- Shelf plank — badge sits on the left of the plank face -->
          <div class="shelf-plank">
            <h2 id="tier-<%= index %>" class="tier-badge"><%= tier.name %></h2>
          </div>

          <!-- Vivace 2026 marquee strip -->
          <div class="shelf-strip" aria-hidden="true">
            <div class="shelf-strip-track">
              <span><%- 'VIVACE 2026   ✦   '.repeat(22) %></span>
              <span><%- 'VIVACE 2026   ✦   '.repeat(22) %></span>
            </div>
          </div>

        </section>
      <% }) %>
    </div>
  </div>

</main>

<%- include('partials/footer') %>

</body>
</html>
